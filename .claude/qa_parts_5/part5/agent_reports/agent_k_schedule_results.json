  "bugs": [
    {
      "id": "BUG-K-01",
      "severity": "medium",
      "summary": "create_activity overrides explicit duration_days=0 when start_date == end_date (compute_duration returns 1 inclusive). Milestones cannot be created with zero duration via API.",
      "repro": "POST /schedules/{id}/activities/ with {\"duration_days\":0,\"start_date\":\"2026-05-01\",\"end_date\":\"2026-05-01\",\"activity_type\":\"milestone\"} \u2192 persisted duration_days=1",
      "location": "backend/app/modules/schedule/service.py:391-393",
      "fix": "Change `if duration == 0 and data.start_date and data.end_date:` to `if duration is None and ...` OR skip recompute when activity_type == 'milestone'."
    },
    {
      "id": "BUG-K-02",
      "severity": "medium",
      "summary": "Sporadic 500 `sqlite3.OperationalError: database is locked` on rapid sequential POST /schedule/schedules/{id}/activities/ \u2014 auth-middleware last_login_at UPDATE races with activity INSERT on the same aiosqlite connection.",
      "repro": "Rapidly POST ~50+ activities with the same admin token to /api/v1/schedule/schedules/{sid}/activities/ \u2014 observed 1 transient 500s in 200 posts.",
      "location": "demo SQLite deploy; seen in pca-v4-serve.log \u2014 UPDATE oe_users_user SET last_login_at collides with INSERT.",
      "fix": "Either (a) suppress last_login_at refresh when the user has been seen in the last N seconds, (b) run login-tracking in a separate connection/transaction, or (c) enable WAL mode on SQLite."
    }
  ]
